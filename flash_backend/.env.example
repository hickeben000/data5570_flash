# Django
SECRET_KEY=change-me
DEBUG=False

# AI provider (optional for local/dev stubs)
GEMINI_API_KEY=
# google-generativeai model id (use gemini-2.5-flash or another listed model if 2.0 is unavailable)
GEMINI_MODEL=gemini-2.0-flash

# Comma-separated hostnames/IPs
ALLOWED_HOSTS=127.0.0.1,localhost

# Frontend origins allowed by CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006

# Comma-separated full origins when CSRF protection is enabled for browser clients
CSRF_TRUSTED_ORIGINS=

# Production security flags
SECURE_SSL_REDIRECT=False
REQUIRE_HTTPS_FOR_AI=False
